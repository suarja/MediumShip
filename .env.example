# Expo client env (committed to the bundle — public values only)
EXPO_PUBLIC_CONVEX_URL=
EXPO_PUBLIC_CONVEX_SITE_URL=
EXPO_PUBLIC_CLERK_PUBLISHABLE_KEY=
EXPO_PUBLIC_EMBED_REFERER_URL=
EXPO_PUBLIC_STATUS_URL=

# RevenueCat (mobile IAP). In __DEV__, Test Store key takes priority when set.
# Test Store: RevenueCat → Apps and providers → Test Store → API key (SDK 9.5.4+).
# Production: platform-specific public SDK keys from Project Settings → API keys.
# Full setup + go-live checklist: docs/setup/payments-revenuecat.md
# NB: IOS_KEY must be a real appl_… prod key, never a copy of the test_… key.
EXPO_PUBLIC_REVENUECAT_TEST_STORE_KEY=
EXPO_PUBLIC_REVENUECAT_IOS_KEY=
EXPO_PUBLIC_REVENUECAT_ANDROID_KEY=
# Entitlement identifier in RevenueCat (default in code: Knowly Pro)
EXPO_PUBLIC_REVENUECAT_ENTITLEMENT_ID=Knowly Pro
# Convex deployment (not Expo): npx convex env set REVENUECAT_ENTITLEMENT_ID "Knowly Pro"
# Optional REST backfill after purchase: npx convex env set REVENUECAT_API_KEY <secret>

# CMS web env. If omitted locally, apps/cms falls back to the Expo public keys.
NEXT_PUBLIC_CONVEX_URL=
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=

# CLERK_JWT_ISSUER_DOMAIN is NOT read here — it is a Convex deployment env var.
# Set it on the deployment so convex/auth.config.ts can validate Clerk JWTs:
#   npx convex env set CLERK_JWT_ISSUER_DOMAIN https://<your-app>.clerk.accounts.dev
# See docs/setup/clerk-auth.md.

# Optional for CMS video enrichment. Required by `convex/youtube/enrich.ts`.
# Set it in Convex as well:
#   npx convex env set YOUTUBE_DATA_API_KEY <key>
YOUTUBE_DATA_API_KEY=

# Cloudflare R2 (hosted-video + cover uploads from the CMS). These are Convex
# DEPLOYMENT env vars — names only here, set the real values on the deployment:
#   npx convex env set R2_TOKEN <token>
#   npx convex env set R2_ACCESS_KEY_ID <id>
#   npx convex env set R2_SECRET_ACCESS_KEY <secret>
#   npx convex env set R2_ENDPOINT https://<account>.r2.cloudflarestorage.com
#   npx convex env set R2_BUCKET <bucket>
# Recommended (public bucket): permanent, persistable URLs for playbackUrl/cover.
#   npx convex env set R2_PUBLIC_URL https://pub-xxxx.r2.dev
R2_TOKEN=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_ENDPOINT=
R2_BUCKET=
R2_PUBLIC_URL=
