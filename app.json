{
  "expo": {
    "name": "Knowly",
    "slug": "knowly",
    "version": "1.0.0",
    "scheme": "knowly",
    "orientation": "default",
    "userInterfaceStyle": "automatic",
    "icon": "./assets/images/icon.png",
    "splash": {
      "image": "./assets/images/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#EFECE5"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.swarecito.knowly",
      "icon": "./assets/images/icon.png"
    },
    "plugins": [
      "expo-router",
      "expo-status-bar",
      "expo-localization",
      "expo-secure-store",
      "expo-web-browser",
      "expo-font",
      [
        "expo-audio",
        {
          "enableBackgroundPlayback": true
        }
      ],
      [
        "expo-video",
        {
          "supportsBackgroundPlayback": true,
          "supportsPictureInPicture": true
        }
      ],
      [
        "expo-image-picker",
        {
          "photosPermission": "MediumShip needs access to your photo library so you can choose a profile picture.",
          "cameraPermission": false
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true
    },
    "android": {
      "package": "com.swarecito.knowly",
      "adaptiveIcon": {
        "foregroundImage": "./assets/images/adaptive-icon.png",
        "backgroundColor": "#EFECE5"
      }
    }
  }
}
