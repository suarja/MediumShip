{
  "expo": {
    "name": "MediumShip",
    "slug": "mediumship",
    "version": "1.0.0",
    "scheme": "mediumship",
    "orientation": "default",
    "userInterfaceStyle": "automatic",
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.swarecito.mediumship"
    },
    "plugins": [
      "expo-router",
      "expo-status-bar",
      "expo-localization",
      "expo-secure-store",
      "expo-web-browser",
      "expo-font",
      [
        "expo-audio",
        {
          "enableBackgroundPlayback": true
        }
      ],
      [
        "expo-video",
        {
          "supportsBackgroundPlayback": true,
          "supportsPictureInPicture": true
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true
    },
    "android": {
      "package": "com.swarecito.mediumship"
    }
  }
}
